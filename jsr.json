{
  "name": "@ismail-elkorchi/bytefold",
  "version": "0.8.1",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./support": "./support/mod.ts"
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "CHANGELOG.md",
      "SECURITY.md",
      "SPEC.md",
      "ARCHITECTURE.md",
      "CONTRIBUTING.md",
      "SUPPORT.md",
      "mod.ts",
      "support/mod.ts",
      "src/**",
      "jsr.json",
      "package.json"
    ],
    "exclude": [
      "dist-test/**",
      "test/**",
      "specs/**",
      "bench/**",
      "node_modules/**",
      "scripts/**",
      "docs/**",
      ".bytefold_meta/**"
    ]
  }
}
